                       echo \"\" ;;\n605\t  esac\n606\t}\n607\t\n608\tconfig_load() {\n609\t  local defaults_file user_file\n610\t  defaults_file=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/../..\" && pwd)/config/default-config.json\"\n611\t  user_file=\"${CLAUDE_PLUGIN_DATA:-}/config.json\"\n612\t\n613\t  _CONFIG_VALUES=()\n614\t\n615\t  if [[ -f \"$defaults_file\" ]]; then\n616\t    while IFS=$'\\t' read -r key val; do\n617\t      _CONFIG_VALUES[\"$key\"]=\"$val\"\n618\t    done < <(jq -r 'to_entries[] | \"\\(.key)\\t\\(.value)\"' \"$defaults_file\" 2>/dev/null || true)\n619\t  fi\n620\t\n621\t  if [[ -n \"${CLAUDE_PLUGIN_DATA:-}\" && -f \"$user_file\" ]]; then\n622\t    while IFS=$'\\t' read -r key val; do\n623\t      _CONFIG_VALUES[\"$key\"]=\"$val\"\n624\t    done < <(jq -r 'to_entries[] | \"\\(.key)\\t\\(.value)\"' \"$user_file\" 2>/dev/null || true)\n625\t  fi\n626\t\n627\t  for key in \"${!_CONFIG_VALUES[@]}\"; do\n628\t    local env_name\n629\t    env_name=\"$(_config_env_var \"$key\")\"\n630\t    if [[ -n \"$env_name\" && -n \"${!env_name:-}\" ]]; then\n631\t      _CONFIG_VALUES[\"$key\"]=\"${!env_name}\"\n632\t    fi\n633\t  done\n634\t\n635\t  _CONFIG_LOADED=1\n636\t}\n637\t\n638\tconfig_get() {\n639\t  local key=\"$1\"\n640\t  [[ -z \"$_CONFIG_LOADED\" ]] && config_load\n641\t  echo \"${_CONFIG_VALUES[$key]:-}\"\n642\t}\n643\t```\n644\t\n645\t- [ ] **Step 5: Run test to verify it passes + commit**\n646\t\n647\t```bash\n648\tbash tests/unit/test-config.sh\n649\t```\n650\tAll pass, then:\n651\t\n652\t```bash\n653\tgit add scripts/lib/config.sh tests/unit/test-config.sh config/default-config.json\n654\tgit commit -m \"feat(v1.5): add lib/config.sh with env > file > defaults precedence\"\n655\t```\n656\t\n657\t---\n658\t\n659\t### Task 2.2: Create `lib/logger.sh` (uses `config_get`)\n660\t\n661\t**Files:**\n662\t- Create: `scripts/lib/logger.sh`\n663\t- Create: `tests/unit/test-logger.sh`\n664\t\n665\t- [ ] **Step 1: Create `tests/unit/test-logger.sh`**\n666\