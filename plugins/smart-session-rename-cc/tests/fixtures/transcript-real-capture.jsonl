\"$DELTA\" '\n1939\t  .accumulated_score = ((.accumulated_score // 0) + $d)\n1940\t  | .domain_guess = ($turn.domain_guess // .domain_guess)\n1941\t  | .active_files_recent = (\n1942\t      ((.active_files_recent // []) + ($turn.all_files_touched // []))\n1943\t      | unique | .[0:20]\n1944\t    )\n1945\t  | .branch = ($turn.branch // .branch // \"\")\n1946\t  | .updated_at = (now | todate)\n1947\t  | .version = \"1.5\"\n1948\t')\n1949\t\n1950\tlog_event debug score_update \"$SESSION_ID\" \"$(jq -nc --argjson d \"$DELTA\" --argjson acc \"$(echo \"$STATE\" | jq -r '.accumulated_score')\" --argjson t \"$TURN_NUM\" --argjson fs \"$FILE_SIZE\" '{delta:$d, acc:$acc, turn:$t, file_size:$fs}')\"\n1951\t\n1952\t# --- 6. Decide (scorer reads last_processed_signature, which still holds the PREVIOUS value) ---\n1953\tDECISION_JSON=$(scorer_should_call_llm \"$STATE\" \"$CURRENT_SIGNATURE\")\n1954\tDECISION=$(echo \"$DECISION_JSON\" | jq -r '.decision')\n1955\tREASON=$(echo \"$DECISION_JSON\" | jq -r '.reason')\n1956\t\n1957\tlog_event info llm_decision \"$SESSION_ID\" \"$(jq -nc --arg d \"$DECISION\" --arg r \"$REASON\" '{decision:$d, reason:$r}')\"\n1958\t\n1959\tREATTACH_INTERVAL=$(config_get reattach_interval)\n1960\tCUR_TITLE=$(echo \"$STATE\" | jq -r '.rendered_title // \"\"')\n1961\t\n1962\tif [[ \"$DECISION\" == \"skip\" ]]; then\n1963\t  # Periodic re-attach\n1964\t  if [[ -n \"$CUR_TITLE\" ]] && (( TURN_NUM % REATTACH_INTERVAL == 0 )); then\n1965\t    if writer_append_title \"$TRANSCRIPT_PATH\" \"$CUR_TITLE\"; then\n1966\t      log_event info title_reattached \"$SESSION_ID\" \"$(jq -nc --arg t \"$CUR_TITLE\" '{title:$t}')\"\n1967\t    fi\n1968\t  fi\n1969\t  # Update signature AFTER decision\n1970\t  STATE=$(echo \"$STATE\" | jq --arg s \"$CURRENT_SIGNATURE\" '.last_processed_signature = $s')\n1971\t  state_save \"$SESSION_ID\" \"$STATE\"\n1972\t  _HOOK_CLEAN_EXIT=1; exit 0\n1973\tfi\n1974\t\n1975\t# --- 7. Call LLM ---\n1976\tCALLS_MADE=$(echo \"$STATE\" | jq -r '.ca