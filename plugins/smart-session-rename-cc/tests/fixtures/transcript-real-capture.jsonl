json-schema.\n1438\t# Portable timeout (timeout/gtimeout/perl fallback). jq-based prompt rendering (multiline-safe).\n1439\t\n1440\t_LLM_JSON_SCHEMA='{\n1441\t  \"type\":\"object\",\n1442\t  \"properties\":{\n1443\t    \"domain\":{\"type\":\"string\",\"minLength\":1,\"maxLength\":30},\n1444\t    \"clauses\":{\"type\":\"array\",\"items\":{\"type\":\"string\",\"minLength\":2,\"maxLength\":50},\"minItems\":1,\"maxItems\":5}\n1445\t  },\n1446\t  \"required\":[\"domain\",\"clauses\"],\n1447\t  \"additionalProperties\":false\n1448\t}'\n1449\t\n1450\t# Picks timeout command: timeout | gtimeout | perl-based | none (no-op)\n1451\t_llm_timeout_wrapper() {\n1452\t  local seconds=\"$1\"\n1453\t  if command -v timeout >/dev/null 2>&1; then\n1454\t    echo \"timeout $seconds\"\n1455\t  elif command -v gtimeout >/dev/null 2>&1; then\n1456\t    echo \"gtimeout $seconds\"\n1457\t  elif command -v perl >/dev/null 2>&1; then\n1458\t    # perl -e 'alarm shift; exec @ARGV' -- N cmd args...\n1459\t    echo \"perl -e alarm_shift_exec $seconds\"\n1460\t  else\n1461\t    echo \"\"\n1462\t  fi\n1463\t}\n1464\t\n1465\t# Runs a command with timeout using the best available wrapper.\n1466\t# Args: seconds, command, args...\n1467\t_llm_with_timeout() {\n1468\t  local seconds=\"$1\"; shift\n1469\t  if command -v timeout >/dev/null 2>&1; then\n1470\t    timeout \"$seconds\" \"$@\"\n1471\t  elif command -v gtimeout >/dev/null 2>&1; then\n1472\t    gtimeout \"$seconds\" \"$@\"\n1473\t  elif command -v perl >/dev/null 2>&1; then\n1474\t    perl -e 'alarm shift; exec @ARGV' \"$seconds\" \"$@\"\n1475\t  else\n1476\t    \"$@\"\n1477\t  fi\n1478\t}\n1479\t\n1480\t# Render prompt template with variable substitution. jq-based, handles multiline/quotes/slashes.\n1481\t_render_prompt() {\n1482\t  local ctx_json=\"$1\"\n1483\t  local template_file\n1484\t  template_file=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")/..\" && pwd)/prompts/generation.md\"\n1485\t  [[ ! -f \"$template_file\" ]] && return 1\n1486\t\n1487\t  jq -nr --rawfile tmpl \"$template_file\" --argjson ctx \"$ctx_json\" '\n1488\t    $ctx\n1489\t    | to_entries\n1490\t    | reduce .[] as $e ($tmpl;\n1491\t        gsub(\"\\\\$\\\\{\" + $e.key + \"\\\\}\"; ($e.value | tostring))\n1492\t      )\n1493\t  '\n1494\t}\n1495\t\n1496\tllm_generate_title() {\n1497\t  local ctx_json=\"$1\"\n1498\t  local prompt\n1499\t  prompt=$(_render_prompt \"$ctx_json\") || { echo '{\"error\":\"prompt_template_missing\"}'; return 1; }\n1500\t\n1501\t  local model timeout_s\n1502\t  model=$(config_get model)\n1503\t  timeout_s=$(config_get llm_timeout_seconds)\n1504\t\n1505\t  local raw rc\n1506\t  raw=$(_llm_with_timeout \"$timeout_s\" claude -p \\\n1507\t    --model \"$model\" \\\n1508\t    --output-format json \\\n1509\t    --no-session-persistence \\\n1510\t    --json-schema \"$_LLM_JSON_SCHEMA\" \\\n1511\t    \"$prompt\" 2>/dev/null)\n1512\t  rc=$?\n1513\t\n1514\t  if [[ $rc -ne 0 ]]; then\n1515\t    echo '{\"error\":\"call_failed\"}'\n1516\t    return 1\n1517\t  fi\n1518\t\n1519\t  if ! echo \"$raw\" | jq . >/dev/null 2>&1; then\n1520\t    echo '{\"error\":\"invalid_output\"}'\n1521\t    return 1\n1522\t  fi\n1523\t\n1524\t  local is_error\n1525\t  is_error=$(echo \"$raw\" | jq -r '[.[] | select(.type == \"result\")] | first | .is_error // false')\n1526\t  if [[ \"$is_error\" == \"true\" ]]; then\n1527\t    echo '{\"error\":\"call_failed\"}'\n1528\t    return 1\n1529\t  fi\n1530\t\n1531\t  local output\n1532\t  output=$(echo \"$raw\" | jq -c '[.[] | select(.type == \"result\")] | first | .structured_output // empty')\n1533\t  if [[ -z \"$output\" || \"$output\" == \"null\" ]]; then\n1534\t    echo '{\"error\":\"invalid_output\"}'\n1535\t    return 1\n1536\t  fi\n1537\t\n1538\t  local cost duration\n1539\t  cost=$(echo \"$raw\" | jq -r '[.[] | select(.type == \"result\")] | first | .total_cost_usd // 0')\n1540\t  duration=$(echo \"$raw\" | jq -r '[.[] | select(.type == \"result\")] | first | .duration_ms // 0')\n1541\t\n1542\t  echo \"$output\" | jq --arg c \"$cost\" --arg d \"$duration\" \\\n1543\t    '. + {_cost_usd: ($c | tonumber), _duration_ms: ($d | tonumber)}'\n1544\t}\n1545\t```\n1546\t\n1547\t- [ ] **Step 5: Run test + commit**\n1548\t\n1549\t```bash\n1550\tbash tests/unit/test-llm.sh\n1551\tgit add scripts/lib/llm.sh tests/mocks/claude tests/unit/test-llm.sh\n1552\tgit commit -m \"feat(v1.5): add lib/llm.sh (jq render, portable timeout, extended mock)\"\n1553\t```\n1554\t\n1555\t---\n1556\t\n1557\t### Task 5.3: Create `lib/validate.sh` with `manual_title_override` support\n1558\t\n1559\tAddresses: separate override from domain anchor (A2) — when `/rename` nativo writes free-form text, render it verbatim; when user invokes `/smart-rename <slug>`, it's a domain anchor.\n1560\t\n1561\t**Files:**\n1562\t- Create: `scripts/lib/validate.sh`\n1563\t- Create: `tests/unit/test-validate.sh`\n1564\t\n1565\t- [ ] **Step 1: Create `tests/unit/test-validate.sh`**\n1566\t\n1567\t```bash\n1568\t#!/usr/bin/env bash\n1569\tset -euo pipefail\n1570\t\n1571\tSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\n1572\tsource \"$SCRIPT_DIR/../../scripts/lib/config.sh\"\n1573\tsource \"$SCRIPT_DIR/../../scripts/lib/validate.sh\"\n1574\t\n1575\tPASS=0; FAIL=0\n1576\tassert_eq() { local d=\"$1\" e=\"$2\" a=\"$3\"; [[ \"$e\" == \"$a\" ]] && { echo \"  ✓ $d\"; ((PASS++)) || true; } || { echo \"  ✗ $d: '$e' vs '$a'\"; ((FAIL++)) || true; }; }\n1577\t\n1578\techo \"=== validate.sh tests ===\"\n1579\texport CLAUDE_PLUGIN_DATA=\"$(mktemp -d)\"\n1580\tconfig_load\n1581\t\n1582\techo \"-- simple render --\"\n1583\tout='{\"domain\":\"auth\",\"clauses\":[\"fix jwt expiry\",\"add tests\"]}'\n1584\ts='{\"rendered_title\":\"\",\"manual_anchor\":null,\"manual_title_override\":null}'\n1585\tr=$(validate_and_render \"$out\" \"$s\")\n1586\tassert_eq \"title\" \"auth: fix jwt expiry, add tests\" \"$(echo \"$r\" | jq -r '.rendered_title')\"\n1587\tassert_eq \"status\" \"ok\" \"$(echo \"$r\" | jq -r '.status')\"\n1588\t\n1589\techo \"-- identical → skip --\"\n1590\ts='{\"rendered_title\":\"auth: fix jwt expiry, add tests\",\"manual_anchor\":null,\"manual_title_override\":null}'\n1591\tassert_eq \"skip identical\" \"skip_identical\" \"$(validate_and_render \"$out\" \"$s\" | jq -r '.status')\"\n1592\t\n1593\techo \"-- manual_anchor overrides domain only (clauses kept) --\"\n1594\ts='{\"rendered_title\":\"\",\"manual_anchor\":\"fernando-custom\",\"manual_title_override\":null}'\n1595\tr=$(validate_and_render \"$out\" \"$s\")\n1596\tassert_eq \"anchor\" \"fernando-custom: fix jwt expiry, add tests\" \"$(echo \"$r\" | jq -r '.rendered_title')\"\n1597\t\n1598\techo \"-- manual_title_override renders verbatim (ignores LLM output) --\"\n1599\ts='{\"rendered_title\":\"\",\"manual_anchor\":null,\"manual_title_override\":\"My raw title with spaces\"}'\n1600\tr=$(validate_and_render \"$out\" \"$s\")\n1601\tassert_eq \"override verbatim\" \"My raw title with spaces\" \"$(echo \"$r\" | jq -r '.rendered_title')\"\n1602\tassert_eq \"status ok\" \"ok\" \"$(echo \"$r\" | jq -r '.status')\"\n1603\t\n1604\techo \"-- dedupe clauses --\"\n1605\tout='{\"domain\":\"auth\",\"clauses\":[\"fix jwt\",\"  fix jwt  \",\"FIX JWT\",\"add tests\"]}'\n1606\ts='{\"rendered_title\":\"\",\"manual_anchor\":null,\"manual_title_override\":null}'\n1607\tassert_eq \"deduped\" \"auth: fix jwt, add tests\" \"$(validate_and_render \"$out\" \"$s\" | jq -r '.rendered_title')\"\n1608\t\n1609\techo \"-- invalid outputs --\"\n1610\tassert_eq \"empty clauses\" \"invalid\" \"$(validate_and_render '{\"domain\":\"x\",\"clauses\":[]}' \"$s\" | jq -r '.status')\"\n1611\tassert_eq \"empty domain\" \"invalid\" \"$(validate_and_render '{\"domain\":\"\",\"clauses\":[\"a\"]}' \"$s\" | jq -r '.status')\"\n1612\t\n1613\techo \"-- error passes through --\"\n1614\tassert_eq \"error\" \"error\" \"$(validate_and_render '{\"error\":\"call_failed\"}' \"$s\" | jq -r '.status')\"\n1615\t\n1616\trm -rf \"$CLAUDE_PLUGIN_DATA\"\n1617\techo \"\"\n1618\techo \"Result: $PASS passed, $FAIL failed\"\n1619\t[[ $FAIL -eq 0 ]]\n1620\t```\n1621\t\n1622\t- [ ] **Step 2: Run test to verify it fails**\n1623\t\n1624\t```bash\n1625\tbash tests/unit/test-validate.sh\n1626\t```\n1627\t\n1628\t- [ ] **Step 3: Create `scripts/lib/validate.sh`**\n1629\t\n1630\t```bash\n1631\t#!/usr/bin/env bash\n1632\t# lib/validate.sh — validate LLM output and render title.\n1633\t# Supports manual_title_override (raw text, for /rename nativo detection) separate from\n1634\t# manual_anchor (domain slug, for /smart-rename <slug>).\n1635\t\n1636\t# Args: llm_output_json, state_json\n1637\t# Stdout: {\"status\":\"ok\"|\"skip_identical\"|\"invalid\"|\"error\", \"rendered_title\":\"...\", \"title_struct\":{...}}\n1638\tvalidate_and_render() {\n1639\t  local output=\"$1\" state=\"$2\"\n1640\t\n1641\t  local err\n1642\t  err=$(echo \"$output\" | jq -r '.error // \"\"')\n1643\t  if [[ -n \"$err\" ]]; then\n1644\t    echo \"$output\" | jq -c --arg e \"$err\" '{status:\"error\", error:$e}'\n1645\t    return 0\n1646\t  fi\n1647\t\n1648\t  # Early exit: manual_title_override wins. Render verbatim; title_struct is minimal.\n1649\t  local override\n1650\t  override=$(echo \"$state\" | jq -r '.manual_title_override // \"\"')\n1651\t  if [[ -n \"$override\" && \"$override\" != \"null\" ]]; then\n1652\t    local prev\n1653\t    prev=$(echo \"$state\" | jq -r '.rendered_title // \"\"')\n1654\t    if [[ \"$prev\" == \"$override\" ]]; then\n1655\t      jq -nc --arg t \"$override\" '{status:\"skip_identical\", rendered_title:$t, title_struct:{domain:$t, clauses:[]}}'\n1656\t    else\n1657\t      jq -nc --arg t \"$override\" '{status:\"ok\", rendered_title:$t, title_struct:{domain:$t, clauses:[]}}'\n1658\t    fi\n1659\t    return 0\n1660\t  fi\n1661\t\n1662\t  local domain clauses_json clauses_count\n1663\t  domain=$(echo \"$output\" | jq -r '.domain // \"\"')\n1664\t  clauses_json=$(echo \"$output\" | jq -c '.clauses // []')\n1665\t  clauses_count=$(echo \"$clauses_json\" | jq 'length')\n1666\t\n1667\t  if [[ -z \"$domain\" || \"$domain\" == \"null\" ]]; then\n1668\t    echo '{\"status\":\"invalid\",\"error\":\"empty_domain\"}'\n1669\t    return 0\n1670\t  fi\n1671\t  if [[ \"$clauses_count\" -eq 0 ]]; then\n1672\t    echo '{\"status\":\"invalid\",\"error\":\"empty_clauses\"}'\n1673\t    return 0\n1674\t  fi\n1675\t\n1676\t  local max_clauses max_domain_chars\n1677\t  max_clauses=$(config_get max_clauses)\n1678\t  max_domain_chars=$(config_get max_domain_chars)\n1679\t  domain=\"${domain:0:$max_domain_chars}\"\n1680\t\n1681\t  local manual_anchor\n1682\t  manual_anchor=$(echo \"$state\" | jq -r '.manual_anchor // \"\"')\n1683\t  if [[ -n \"$manual_anchor\" && \"$manual_anchor\" != \"null\" ]]; then\n1684\t    domain=\"$manual_anchor\"\n1685\t  fi\n1686\t\n1687\t  local deduped\n1688\t  deduped=$(echo \"$clauses_json\" | jq -c --argjson max \"$max_clauses\" '\n1689\t    [.[]\n1690\t      | gsub(\"^\\\\s+|\\\\s+$\"; \"\")\n1691\t      | gsub(\"\\\\s+\"; \" \")\n1692\t      | select(length > 0)\n1693\t    ]\n1694\t    | reduce .[] as $c (\n1695\t        {seen: {}, out: []};\n1696\t        ($c | ascii_downcase) as $k\n1697\t        | if .seen[$k] then .\n1698\t          else .seen[$k] = true | .out += [$c]\n1699\t          end\n1700\t      )\n1701\t    | .out[:$max]\n1702\t  ')\n1703\t\n1704\t  local deduped_count\n1705\t  deduped_count=$(echo \"$deduped\" | jq 'length')\n1706\t  if [[ \"$deduped_count\" -eq 0 ]]; then\n1707\t    echo '{\"status\":\"invalid\",\"error\":\"all_clauses_empty_after_dedupe\"}'\n1708\t    return 0\n1709\t  fi\n1710\t\n1711\t  local joined rendered\n1712\t  joined=$(echo \"$deduped\" | jq -r 'join(\", \")')\n1713\t  rendered=\"$domain: $joined\"\n1714\t\n1715\t  local prev\n1716\t  prev=$(echo \"$state\" | jq -r '.rendered_title // \"\"')\n1717\t  if [[ \"$prev\" == \"$rendered\" ]]; then\n1718\t    jq -nc --arg t \"$rendered\" --arg d \"$domain\" --argjson cl \"$deduped\" \\\n1719\t      '{status:\"skip_identical\", rendered_title:$t, title_struct:{domain:$d, clauses:$cl}}'\n1720\t    return 0\n1721\t  fi\n1722\t\n1723\t  jq -nc --arg t \"$rendered\" --arg d \"$domain\" --argjson cl \"$deduped\" \\\n1724\t    '{status:\"ok\", rendered_title:$t, title_struct:{domain:$d, clauses:$cl}}'\n1725\t}\n1726\t```\n1727\t\n1728\t- [ ] **Step 4: Run test + commit**\n1729\t\n1730\t```bash\n1731\tbash tests/unit/test-validate.sh\n1732\tgit add scripts/lib/validate.sh tests/unit/test-validate.sh\n1733\tgit commit -m \"feat(v1.5): add lib/validate.sh (override vs anchor, dedupe, render)\"\n1734\t```\n1735\t\n1736\t---\n1737\t\n1738\t### Task 5.4: Create `lib/writer.sh` (return-code checked by callers)\n1739\t\n1740\t**Files:**\n1741\t- Create: `scripts/lib/writer.sh`\n1742\t- Create: `tests/unit/test-writer.sh`\n1743\t\n1744\t- [ ] **Step 1: Create `tests/unit/test-writer.sh`**\n1745\t\n1746\t```bash\n1747\t#!/usr/bin/env bash\n1748\tset -euo pipefail\n1749\t\n1750\tSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\n1751\tsource \"$SCRIPT_DIR/../../scripts/lib/writer.sh\"\n1752\t\n1753\tPASS=0; FAIL=0\n1754\tassert_eq() { local d=\"$1\" e=\"$2\" a=\"$3\"; [[ \"$e\" == \"$a\" ]] && { echo \"  ✓ $d\"; ((PASS++)) || true; } || { echo \"  ✗ $d: '$e' vs '$a'\"; ((FAIL++)) || true; }; }\n1755\t\n1756\techo \"=== writer.sh tests ===\"\n1757\ttmp=$(mktemp)\n1758\tcat > \"$tmp\" <<'JSONL'\n1759\t{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":\"hello\"}}\n1760\t{\"type\":\"assistant\",\"message\":{\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"hi\"}]}}\n1761\tJSONL\n1762\t\n1763\techo \"-- append custom-title --\"\n1764\twriter_append_title \"$tmp\" \"auth: fix jwt\"\n1765\tassert_eq \"type\" \"custom-title\" \"$(tail -1 \"$tmp\" | jq -r '.type')\"\n1766\tassert_eq \"customTitle\" \"auth: fix jwt\" \"$(tail -1 \"$tmp\" | jq -r '.customTitle')\"\n1767\t\n1768\techo \"-- second append adds second line --\"\n1769\twriter_append_title \"$tmp\" \"auth: fix jwt, add tests\"\n1770\tassert_eq \"two records\" \"2\" \"$(grep -c '\"type\":\"custom-title\"' \"$tmp\")\"\n1771\t\n1772\techo \"-- read last --\"\n1773\tassert_eq \"last title\" \"auth: fix jwt, add tests\" \"$(writer_get_last_custom_title \"$tmp\")\"\n1774\t\n1775\techo \"-- missing transcript fails cleanly --\"\n1776\tif writer_append_title \"/nonexistent.jsonl\" \"x\" 2>/dev/null; then\n1777\t  echo \"  ✗ should fail\"; ((FAIL++)) || true\n1778\telse\n1779\t  echo \"  ✓ failed\"; ((PASS++)) || true\n1780\tfi\n1781\t\n1782\techo \"-- get_last on file without custom-title returns empty --\"\n1783\tempty_file=$(mktemp)\n1784\techo '{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":\"x\"}}' > \"$empty_file\"\n1785\tassert_eq \"empty\" \"\" \"$(writer_get_last_custom_title \"$empty_file\")\"\n1786\t\n1787\techo \"-- title with quotes/newlines is properly JSON-encoded --\"\n1788\twriter_append_title \"$tmp\" 'title with \"quotes\"'\n1789\tassert_eq \"quoted\" 'title with \"quotes\"' \"$(writer_get_last_custom_title \"$tmp\")\"\n1790\t\n1791\trm -f \"$tmp\" \"$empty_file\"\n1792\techo \"\"\n1793\techo \"Result: $PASS passed, $FAIL failed\"\n1794\t[[ $FAIL -eq 0 ]]\n1795\t```\n1796\t\n1797\t- [ ] **Step 2: Run test to verify it fails**\n1798\t\n1799\t```bash\n1800\tbash tests/unit/test-writer.sh\n1801\t```\n1802\t\n1803\t- [ ] **Step 3: Create `scripts/lib/writer.sh`**\n1804\t\n1805\t```bash\n1806\t#!/usr/bin/env bash\n1807\t# lib/writer.sh — append custom-title records to session JSONL.\n1808\t# Returns non-zero on failure so callers can avoid promoting state prematurely.\n1809\t\n1810\twriter_append_title() {\n1811\t  local transcript=\"$1\" title=\"$2\"\n1812\t  [[ ! -f \"$transcript\" ]] && return 1\n1813\t  [[ ! -w \"$transcript\" ]] && return 1\n1814\t  jq -nc --arg t \"$title\" '{type:\"custom-title\", customTitle:$t}' >> \"$transcript\"\n1815\t}\n1816\t\n1817\twriter_get_last_custom_title() {\n1818\t  local transcript=\"$1\"\n1819\t  [[ ! -r \"$transcript\" ]] &&